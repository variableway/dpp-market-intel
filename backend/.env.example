# DPP Market Intel Backend Configuration
# Copy this file to .env and fill in your values

# Dashboard data provider: csv | sqlite
DASHBOARD_PROVIDER=csv

# SQLite database path (only used when DASHBOARD_PROVIDER=sqlite)
# DASHBOARD_DATABASE_PATH=data/dashboard.db

# News data provider: json_seed | rss
NEWS_PROVIDER=json_seed

# RSS feeds (only used when NEWS_PROVIDER=rss, comma-separated)
# NEWS_RSS_FEEDS=https://example.com/feed.xml

# UN Comtrade API key (register at https://comtradeplus.un.org/)
UN_COMTRADE_API_KEY=

# CORS origins (comma-separated, default: *)
# CORS_ORIGINS=*
